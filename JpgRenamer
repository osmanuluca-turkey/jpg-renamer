if DND_MEVCUT:
    bilgi.append("Surukle-birak: AKTIF")
else:
    bilgi.append("Surukle-birak: YOK")
if OCR_MEVCUT:
    bilgi.append("OCR: AKTIF")
bilgi.append("Kisayollar: Sol/Sag Ok | Ctrl+O | Ctrl+R | F5")

